# Backend Environment Variables
# Kopyalayın: cp .env.example .env

PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/mdchat

# JWT
JWT_SECRET=mdchat_super_secret_jwt_key_change_this_in_production
JWT_REFRESH_SECRET=mdchat_refresh_secret_change_this_too
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Gmail SMTP
# Google Hesabı > Güvenlik > 2 Adımlı Doğrulama > Uygulama Şifreleri
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# Frontend URL (CORS için)
FRONTEND_URL=http://localhost:3000

# Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
